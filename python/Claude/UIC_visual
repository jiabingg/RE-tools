    # ---------------------------------------------------------------
    # Data Loading
    # ---------------------------------------------------------------
    def _load_projects(self):
        """Load UIC project list from database."""
        self.status_var.set("Loading project list...")
        self.update_idletasks()

        def _do_load():
            try:
                df = run_query(SQL_PROJECTS)
                self.after(0, lambda: self._populate_projects(df))
            except Exception as e:
                self.after(0, lambda: self._show_error(
                    f"Cannot connect to database:\n{e}\n\n"
                    "Loading from embedded sample data instead."
                ))
                self.after(0, self._load_sample_projects)

        threading.Thread(target=_do_load, daemon=True).start()

    def _load_sample_projects(self):
        """Load from the bundled CSV if DB is unavailable."""
        sample_path = os.path.join(os.path.dirname(__file__),
                                    "uic_projects.csv")
        if os.path.exists(sample_path):
            df = pd.read_csv(sample_path, dtype=str)
            df["WELL_COUNT"] = pd.to_numeric(df.get("WELL_COUNT", 0),
                                              errors="coerce").fillna(0).astype(int)
            self._populate_projects(df)
        else:
            self.status_var.set("No database connection and no sample data file found.")

    def _populate_projects(self, df):
        """Fill the project listbox."""
        self.df_projects = df
        self._all_proj_items = []
        self.proj_listbox.delete(0, "end")
        for _, row in df.iterrows():
            code = str(row.get("UIC_PROJ_CDE", ""))
            desc = str(row.get("UIC_PROJ_DESC", ""))[:40]
            status = str(row.get("CURRENT_STATUS", ""))
            wc = str(row.get("WELL_COUNT", 0))
            display = f"{code:<14} {desc:<42} {status:<12} ({wc} wells)"
            self._all_proj_items.append((code, display))
            self.proj_listbox.insert("end", display)
        self.status_var.set(f"Loaded {len(df)} UIC projects. Select and click Load.")

    def _filter_projects(self, *args):
        """Filter project list by search term."""
        term = self.search_var.get().lower()
        self.proj_listbox.delete(0, "end")
        for code, display in self._all_proj_items:
            if term in display.lower():
                self.proj_listbox.insert("end", display)

    def _on_selection_change(self, event=None):
        sel = self.proj_listbox.curselection()
        self.sel_label.config(text=f"Selected: {len(sel)} project(s)")

    def _get_selected_codes(self):
        """Get project codes from current listbox selection."""
        sel_indices = self.proj_listbox.curselection()
        codes = []
        visible_items = self.proj_listbox.get(0, "end")
        for idx in sel_indices:
            display = visible_items[idx]
            # Extract code from the display string (first 14 chars, trimmed)
            code = display[:14].strip()
            codes.append(code)
        return codes

    def _on_load_data(self):
        """Load well and production data for selected projects."""
        codes = self._get_selected_codes()
        if not codes:
            messagebox.showwarning("No Selection",
                                   "Please select at least one project.")
            return
        self.selected_codes = codes
        self.load_btn.config(state="disabled")
        self.status_var.set(f"Loading data for {len(codes)} project(s)...")
        self.update_idletasks()

        def _do_load():
            try:
                df_w = run_query(sql_wells(codes))
                df_p = run_query(sql_production(codes))
                self.after(0, lambda: self._display_results(df_w, df_p))
            except Exception as e:
                self.after(0, lambda: self._show_error(str(e)))
            finally:
                self.after(0, lambda: self.load_btn.config(state="normal"))

        threading.Thread(target=_do_load, daemon=True).start()

    # ---------------------------------------------------------------
    # Display Results
    # ---------------------------------------------------------------
    def _display_results(self, df_wells, df_prod):
        self.df_wells = df_wells
        self.df_prod = df_prod

        # Parse dates
        if "MONTH_DT" in df_prod.columns:
            df_prod["MONTH_DT"] = pd.to_datetime(df_prod["MONTH_DT"],
                                                   errors="coerce")
        # Fill NaN with 0 for numeric columns
        num_cols = ["OIL_PROD", "WATER_PROD", "GAS_PROD", "GROSS_PROD",
                    "STEAM_INJ", "WATER_INJ", "GAS_INJ"]
        for c in num_cols:
            if c in df_prod.columns:
                df_prod[c] = pd.to_numeric(df_prod[c], errors="coerce").fillna(0)

        self._update_summary_cards()
        self._build_well_table()
        self._build_injection_chart()
        self._build_production_chart()
        self._build_cumulative_chart()
        self._build_well_map()

        codes_str = ", ".join(self.selected_codes[:5])
        if len(self.selected_codes) > 5:
            codes_str += f" +{len(self.selected_codes) - 5} more"
        self.status_var.set(
            f"Loaded {len(df_wells)} wells, {len(df_prod)} months of data "
            f"for projects: {codes_str}"
        )

    def _update_summary_cards(self):
        """Show summary metric cards above the notebook."""
        for w in self.cards_frame.winfo_children():
            w.destroy()

        df = self.df_wells
        cards = [
            ("Total Wells", len(df), COLORS["header"]),
            ("Producers", len(df[df["PRIM_PURP_TYPE_CDE"] == "PROD"])
             if "PRIM_PURP_TYPE_CDE" in df.columns else 0, COLORS["prod"]),
            ("Injectors", len(df[df["PRIM_PURP_TYPE_CDE"] == "INJ"])
             if "PRIM_PURP_TYPE_CDE" in df.columns else 0, COLORS["inj"]),
            ("In Service", len(df[df["IN_SVC_INDC"] == "Y"])
             if "IN_SVC_INDC" in df.columns else 0, COLORS["active"]),
            ("Fields", df["FLD_NME"].nunique()
             if "FLD_NME" in df.columns else 0, COLORS["obsn"]),
        ]

        for label, value, color in cards:
            card = tk.Frame(self.cards_frame, bg="white", bd=1,
                            relief="solid", highlightthickness=0)
            card.pack(side="left", padx=4, pady=2, fill="x", expand=True)
            tk.Label(card, text=label, font=("Segoe UI", 9),
                     fg="#6b7280", bg="white").pack(anchor="w", padx=10, pady=(6, 0))
            tk.Label(card, text=str(value), font=("Segoe UI", 20, "bold"),
                     fg=color, bg="white").pack(anchor="w", padx=10, pady=(0, 6))

    # ---------------------------------------------------------------
    # Tab 1: Well List Table
    # ---------------------------------------------------------------
    def _build_well_table(self):
        for w in self.tab_wells.winfo_children():
            w.destroy()

        # Filter bar
        fbar = ttk.Frame(self.tab_wells)
        fbar.pack(fill="x", pady=(5, 5), padx=5)

        ttk.Label(fbar, text="Search:").pack(side="left")
        self.well_search_var = tk.StringVar()
        self.well_search_var.trace_add("write", self._filter_well_table)
        ttk.Entry(fbar, textvariable=self.well_search_var,
                  width=20).pack(side="left", padx=5)

        ttk.Label(fbar, text="Purpose:").pack(side="left", padx=(10, 0))
        self.well_purpose_var = tk.StringVar(value="ALL")
        purpose_cb = ttk.Combobox(fbar, textvariable=self.well_purpose_var,
                                   values=["ALL", "PROD", "INJ", "OBSN"],
                                   width=8, state="readonly")
        purpose_cb.pack(side="left", padx=5)
        purpose_cb.bind("<<ComboboxSelected>>", self._filter_well_table)

        self.well_count_label = ttk.Label(
            fbar, text=f"Showing {len(self.df_wells)} wells")
        self.well_count_label.pack(side="right", padx=5)

        # Treeview
        cols = ["WELL_NME", "WELL_API_NBR", "FLD_NME",
                "PRIM_PURP_TYPE_CDE", "ENGR_STRG_NME",
                "ACTV_INDC", "IN_SVC_INDC", "UIC_PROJ_CDE"]
        headers = ["Well Name", "API Number", "Field",
                   "Purpose", "Eng Strategy",
                   "Active", "In Svc", "Project"]
        widths = [140, 110, 100, 70, 120, 50, 50, 100]

        tree_frame = ttk.Frame(self.tab_wells)
        tree_frame.pack(fill="both", expand=True, padx=5, pady=(0, 5))

        xsb = ttk.Scrollbar(tree_frame, orient="horizontal")
        ysb = ttk.Scrollbar(tree_frame, orient="vertical")

        self.well_tree = ttk.Treeview(
            tree_frame, columns=cols, show="headings",
            xscrollcommand=xsb.set, yscrollcommand=ysb.set
        )
        xsb.config(command=self.well_tree.xview)
        ysb.config(command=self.well_tree.yview)

        for col, hdr, w in zip(cols, headers, widths):
            self.well_tree.heading(col, text=hdr,
                                   command=lambda c=col: self._sort_tree(c))
            self.well_tree.column(col, width=w, minwidth=40)

        self.well_tree.pack(side="left", fill="both", expand=True)
        ysb.pack(side="right", fill="y")
        xsb.pack(side="bottom", fill="x")

        # Configure row tags for coloring
        self.well_tree.tag_configure("PROD", foreground=COLORS["prod"])
        self.well_tree.tag_configure("INJ", foreground=COLORS["inj"])
        self.well_tree.tag_configure("OBSN", foreground=COLORS["obsn"])
        self.well_tree.tag_configure("stripe", background="#f8fafc")

        self._populate_well_tree(self.df_wells)

    def _populate_well_tree(self, df):
        """Insert rows into the well treeview."""
        tree = self.well_tree
        tree.delete(*tree.get_children())
        cols = ["WELL_NME", "WELL_API_NBR", "FLD_NME",
                "PRIM_PURP_TYPE_CDE", "ENGR_STRG_NME",
                "ACTV_INDC", "IN_SVC_INDC", "UIC_PROJ_CDE"]
        for i, (_, row) in enumerate(df.iterrows()):
            vals = [str(row.get(c, "")) for c in cols]
            purpose = str(row.get("PRIM_PURP_TYPE_CDE", ""))
            tags = []
            if purpose in ("PROD", "INJ", "OBSN"):
                tags.append(purpose)
            if i % 2 == 1:
                tags.append("stripe")
            tree.insert("", "end", values=vals, tags=tuple(tags))
        self.well_count_label.config(text=f"Showing {len(df)} wells")

    def _filter_well_table(self, *args):
        """Filter well table by search and purpose."""
        df = self.df_wells
        term = self.well_search_var.get().lower()
        purpose = self.well_purpose_var.get()
        if term:
            mask = (
                df["WELL_NME"].str.lower().str.contains(term, na=False) |
                df["WELL_API_NBR"].astype(str).str.contains(term, na=False) |
                df["ENGR_STRG_NME"].str.lower().str.contains(term, na=False)
            )
            df = df[mask]
        if purpose != "ALL":
            df = df[df["PRIM_PURP_TYPE_CDE"] == purpose]
        self._populate_well_tree(df)

    def _sort_tree(self, col):
        """Sort treeview by column."""
        df = self.df_wells
        # Toggle ascending/descending
        if not hasattr(self, "_sort_asc"):
            self._sort_asc = {}
        asc = not self._sort_asc.get(col, True)
        self._sort_asc[col] = asc
        df = df.sort_values(col, ascending=asc, na_position="last")
        self.df_wells = df
        self._filter_well_table()

    # ---------------------------------------------------------------
    # Tab 2: Injection Chart
    # ---------------------------------------------------------------
    def _build_injection_chart(self):
        for w in self.tab_inj.winfo_children():
            w.destroy()

        df = self.df_prod.copy()
        if df.empty or "MONTH_DT" not in df.columns:
            ttk.Label(self.tab_inj, text="No injection data available.",
