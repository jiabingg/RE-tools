def fmt_num(v):
    """Format a number for display."""
    if pd.isna(v) or v == "":
        return "—"
    try:
        n = float(v)
    except (ValueError, TypeError):
        return str(v)
    if abs(n) >= 1e6:
        return f"{n / 1e6:.1f}M"
    if abs(n) >= 1e3:
        return f"{n / 1e3:.1f}K"
    return f"{int(round(n)):,}"


