def get_connection():
    """Create a database connection."""
    if oracledb is None:
        raise RuntimeError(
            "No Oracle driver found. Install oracledb:\n"
            "  pip install oracledb\n"
            "or oracledb:\n"
            "  pip install oracledb"
        )
    if not DB_CONFIG["user"]:
        raise RuntimeError(
            "Database credentials not configured.\n"
            "Set environment variables ORACLE_USER, ORACLE_PASSWORD, ORACLE_DSN\n"
            "or edit DB_CONFIG in uic_dashboard.py"
        )
    return oracledb.connect(**DB_CONFIG)


def run_query(sql, params=None):
    """Execute a query and return a DataFrame."""
    conn = get_connection()
    try:
        df = pd.read_sql(sql, conn, params=params)
    finally:
        conn.close()
    return df


# ---------------------------------------------------------------------------
# SQL Queries
# ---------------------------------------------------------------------------
SQL_PROJECTS = """
SELECT p.UIC_PROJ_CDE,
       p.UIC_PROJ_DESC,
       ft.FLUID_TYPE_DESC,
       rt.RCVY_TYPE_DESC,
       p.MAX_WELL_CNT,
       p.MAX_BPD_INJ_VOL,
       (SELECT COUNT(*)
        FROM RPLC_UICPROJECT.UIC_PROJ_WELL pw2
        WHERE pw2.UIC_PROJ_ID = p.UIC_PROJ_ID) AS WELL_COUNT,
       (SELECT st.STAT_TYPE_DESC
        FROM RPLC_UICPROJECT.UIC_PROJ_STAT ps
        JOIN RPLC_UICPROJECT.STAT_TYPE st ON ps.STAT_TYPE_ID = st.STAT_TYPE_ID
        WHERE ps.UIC_PROJ_ID = p.UIC_PROJ_ID
          AND ps.TERM_DTTM IS NULL
          AND ROWNUM = 1) AS CURRENT_STATUS
FROM RPLC_UICPROJECT.UIC_PROJ p
LEFT JOIN RPLC_UICPROJECT.FLUID_TYPE ft ON p.FLUID_TYPE_ID = ft.FLUID_TYPE_ID
LEFT JOIN RPLC_UICPROJECT.RCVY_TYPE rt ON p.RCVY_TYPE_ID = rt.RCVY_TYPE_ID
ORDER BY p.UIC_PROJ_CDE
"""


def sql_wells(proj_codes):
    in_list = ", ".join(f"'{c}'" for c in proj_codes)
    return f"""
SELECT DISTINCT
       cd.cmpl_nme        AS WELL_NME,
       cd.well_api_nbr    AS WELL_API_NBR,
       cd.opnl_fld        AS FLD_NME,
       cd.prim_purp_type_cde AS PRIM_PURP_TYPE_CDE,
       cd.engr_strg_nme   AS ENGR_STRG_NME,
       cd.actv_indc       AS ACTV_INDC,
       cd.in_svc_indc     AS IN_SVC_INDC,
       p.UIC_PROJ_CDE,
       fl.XCRD,
       fl.YCRD
FROM RPLC_UICPROJECT.UIC_PROJ_WELL pw
JOIN RPLC_UICPROJECT.UIC_PROJ p
     ON pw.UIC_PROJ_ID = p.UIC_PROJ_ID
JOIN dwrptg.cmpl_dmn cd
     ON pw.FAC_ID = cd.well_fac_id
     AND cd.actv_indc = 'Y'
LEFT JOIN dwrptg.fac_lctn_dmn fl
     ON cd.well_fac_id = fl.fac_id
WHERE p.UIC_PROJ_CDE IN ({in_list})
ORDER BY p.UIC_PROJ_CDE, cd.prim_purp_type_cde, cd.cmpl_nme
"""


def sql_production(proj_codes):
    in_list = ", ".join(f"'{c}'" for c in proj_codes)
    return f"""
SELECT TRUNC(cmf.eftv_dttm, 'MM')          AS MONTH_DT,
       SUM(cmf.aloc_oil_prod_vol_qty)       AS OIL_PROD,
       SUM(cmf.aloc_wtr_prod_vol_qty)       AS WATER_PROD,
       SUM(cmf.aloc_gas_prod_vol_qty)       AS GAS_PROD,
       SUM(cmf.aloc_gros_prod_vol_qty)      AS GROSS_PROD,
       SUM(cmf.aloc_stm_inj_vol_qty)        AS STEAM_INJ,
       SUM(cmf.aloc_wtr_inj_vol_qty)        AS WATER_INJ,
       SUM(cmf.aloc_gas_inj_vol_qty)        AS GAS_INJ
FROM RPLC_UICPROJECT.UIC_PROJ_WELL pw
JOIN RPLC_UICPROJECT.UIC_PROJ p
     ON pw.UIC_PROJ_ID = p.UIC_PROJ_ID
JOIN dwrptg.cmpl_dmn cd
     ON pw.FAC_ID = cd.well_fac_id
     AND cd.actv_indc = 'Y'
JOIN dwrptg.cmpl_mnly_fact cmf
     ON cd.cmpl_dmn_key = cmf.cmpl_dmn_key
WHERE p.UIC_PROJ_CDE IN ({in_list})
  AND cmf.eftv_dttm >= ADD_MONTHS(TRUNC(SYSDATE, 'MM'), -120)
GROUP BY TRUNC(cmf.eftv_dttm, 'MM')
ORDER BY TRUNC(cmf.eftv_dttm, 'MM')
"""


