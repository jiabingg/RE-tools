    # ---------------------------------------------------------------
    # Tab 4: Cumulative Chart
    # ---------------------------------------------------------------
    def _build_cumulative_chart(self):
        for w in self.tab_cum.winfo_children():
            w.destroy()

        df = self.df_prod.copy()
        if df.empty or "MONTH_DT" not in df.columns:
            ttk.Label(self.tab_cum, text="No data available.",
                      font=("Segoe UI", 12)).pack(pady=40)
            return

        # Compute cumulatives
        df = df.sort_values("MONTH_DT")
        df["CUM_OIL"]   = df["OIL_PROD"].cumsum()
        df["CUM_WATER"] = df["WATER_PROD"].cumsum()
        df["CUM_GAS"]   = df["GAS_PROD"].cumsum()
        df["CUM_STEAM"] = df["STEAM_INJ"].cumsum()
        df["CUM_WINJ"]  = df["WATER_INJ"].cumsum()
        df["CUM_GINJ"]  = df["GAS_INJ"].cumsum()

        fig = Figure(figsize=(12, 5), dpi=100, facecolor="white")
        ax = fig.add_subplot(111)
        dates = df["MONTH_DT"]

        # Production cumulatives (solid lines)
        ax.plot(dates, df["CUM_OIL"], color=COLORS["cum_oil"],
                linewidth=2.5, label="Cum Oil Prod")
        ax.plot(dates, df["CUM_WATER"], color=COLORS["cum_water"],
                linewidth=1.8, label="Cum Water Prod")

        # Injection cumulatives (dashed lines)
        ax.plot(dates, df["CUM_STEAM"], color=COLORS["cum_steam"],
                linewidth=2, linestyle="--", label="Cum Steam Inj")
        ax.plot(dates, df["CUM_WINJ"], color=COLORS["cum_winj"],
                linewidth=1.5, linestyle="--", label="Cum Water Inj")
        ax.plot(dates, df["CUM_GINJ"], color=COLORS["cum_ginj"],
                linewidth=1.5, linestyle=":", label="Cum Gas Inj")

        ax.set_title("Cumulative Production & Injection", fontsize=13,
                     fontweight="bold", color=COLORS["header"], pad=12)
        ax.set_ylabel("Cumulative Volume (bbl)", fontsize=10)
        ax.legend(loc="upper left", fontsize=9, framealpha=0.9)
        ax.xaxis.set_major_formatter(mdates.DateFormatter("%Y-%m"))
        ax.xaxis.set_major_locator(mdates.YearLocator())
        ax.tick_params(axis="x", rotation=45, labelsize=8)
        ax.tick_params(axis="y", labelsize=9)
        ax.yaxis.set_major_formatter(plt.FuncFormatter(
            lambda x, _: fmt_num(x)))
        ax.grid(axis="y", alpha=0.3, linestyle="--")
        ax.set_axisbelow(True)
        fig.tight_layout()

        canvas = FigureCanvasTkAgg(fig, self.tab_cum)
        canvas.draw()
        toolbar = NavigationToolbar2Tk(canvas, self.tab_cum)
        toolbar.update()
        canvas.get_tk_widget().pack(fill="both", expand=True)

    # ---------------------------------------------------------------
    # Tab 5: Well Map
    # ---------------------------------------------------------------
    def _build_well_map(self):
        for w in self.tab_map.winfo_children():
            w.destroy()

        df = self.df_wells.copy()
        df["XCRD"] = pd.to_numeric(df.get("XCRD"), errors="coerce")
        df["YCRD"] = pd.to_numeric(df.get("YCRD"), errors="coerce")
        df = df.dropna(subset=["XCRD", "YCRD"])
        df = df[(df["XCRD"] > 0) & (df["YCRD"] > 0)]

        if df.empty:
            ttk.Label(self.tab_map, text="No coordinate data available for map.",
                      font=("Segoe UI", 12)).pack(pady=40)
            return

        fig = Figure(figsize=(12, 7), dpi=100, facecolor="white")
        ax = fig.add_subplot(111)

        # Group by purpose and status
        groups = {
            ("PROD", True):  {"marker": "o", "color": COLORS["prod"],
                              "label": "Producer (in svc)", "s": 30, "alpha": 0.85},
            ("PROD", False): {"marker": "o", "color": COLORS["idle"],
                              "label": "Producer (out of svc)", "s": 20, "alpha": 0.4},
            ("INJ", True):   {"marker": "^", "color": COLORS["inj"],
                              "label": "Injector (in svc)", "s": 35, "alpha": 0.85},
            ("INJ", False):  {"marker": "^", "color": COLORS["idle"],
                              "label": "Injector (out of svc)", "s": 20, "alpha": 0.4},
            ("OBSN", True):  {"marker": "s", "color": COLORS["obsn"],
                              "label": "Observation", "s": 25, "alpha": 0.85},
            ("OBSN", False): {"marker": "s", "color": COLORS["obsn"],
                              "label": "Observation (out)", "s": 15, "alpha": 0.4},
        }

        for (purpose, in_svc), style in groups.items():
            mask = (df["PRIM_PURP_TYPE_CDE"] == purpose)
            if in_svc:
                mask = mask & (df["IN_SVC_INDC"] == "Y")
            else:
                mask = mask & (df["IN_SVC_INDC"] != "Y")
            sub = df[mask]
            if len(sub) > 0:
                ax.scatter(sub["XCRD"], sub["YCRD"],
                           marker=style["marker"], c=style["color"],
                           s=style["s"], alpha=style["alpha"],
                           label=style["label"], edgecolors="white",
                           linewidths=0.5, zorder=3)

        # Also plot any other purpose types
        other_mask = ~df["PRIM_PURP_TYPE_CDE"].isin(["PROD", "INJ", "OBSN"])
        other = df[other_mask]
        if len(other) > 0:
            ax.scatter(other["XCRD"], other["YCRD"],
                       marker="D", c="#9ca3af", s=20, alpha=0.5,
                       label="Other", edgecolors="white", linewidths=0.5)

        ax.set_title("Well Locations (State Plane Coordinates)", fontsize=13,
                     fontweight="bold", color=COLORS["header"], pad=12)
        ax.set_xlabel("Easting (ft)", fontsize=10)
        ax.set_ylabel("Northing (ft)", fontsize=10)
        ax.legend(loc="best", fontsize=8, framealpha=0.9, markerscale=1.5)
        ax.grid(True, alpha=0.2, linestyle="--")
        ax.set_axisbelow(True)
        ax.set_aspect("equal", adjustable="datalim")
        ax.tick_params(labelsize=8)
        ax.xaxis.set_major_formatter(plt.FuncFormatter(
            lambda x, _: f"{x:,.0f}"))
        ax.yaxis.set_major_formatter(plt.FuncFormatter(
            lambda x, _: f"{x:,.0f}"))
        fig.tight_layout()

        canvas = FigureCanvasTkAgg(fig, self.tab_map)
        canvas.draw()
        toolbar = NavigationToolbar2Tk(canvas, self.tab_map)
        toolbar.update()
        canvas.get_tk_widget().pack(fill="both", expand=True)

